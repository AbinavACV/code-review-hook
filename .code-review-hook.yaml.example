# code-review-hook configuration
# Copy this file to .code-review-hook.yaml in your repo root to customize behavior.
# CLI flags in .pre-commit-config.yaml (args:) take precedence over values here.

# LLM endpoint configuration.
# API key must be set via the LLM_API_KEY environment variable.
# Do not commit a real key here.
base_url: https://api.openai.com/v1    # or your LLM gateway URL (--base-url flag)
api_key: ""                             # use LLM_API_KEY env var instead
model: gpt-4o-mini                      # any model your endpoint supports (--model flag)

# Maximum number of diff lines to send to the LLM.
# Larger diffs cost more tokens. Diff is truncated if it exceeds this.
# CLI flag: --max-diff-lines
max_diff_lines: 500

# Severity level that triggers a commit block.
# Options: error (default), warning, info
#   "error"   = only block on bugs and security issues
#   "warning" = also block on performance issues
#   "info"    = block on style issues too (very strict)
# CLI flag: --severity-threshold
severity_threshold: error

# Glob patterns for files to exclude from review.
# Useful for generated files, lock files, and vendored code.
# No CLI flag equivalent — set this in the YAML file.
file_exclude_patterns:
  - "*.lock"
  - "go.sum"
  - "*.pb.go"
  - "vendor/**"
  - "*.min.js"

# Path to a markdown file with team code review rules (relative to repo root).
# The file content is injected into the system prompt as a "Team rules" section.
# CLI flag: --rules-file
# rules_file: rules.md

# Additional instructions appended to the system prompt (after team rules).
# Use this for ad-hoc per-repo tweaks. For extensive rules, use rules_file instead.
# No CLI flag equivalent — set this in the YAML file.
# custom_prompt: |
#   This project follows the Google Go style guide.
#   Flag any exported function without a godoc comment as a warning.

# Whether to block commits on warnings (overrides severity_threshold).
# CLI flag: --fail-on-warning
fail_on_warning: false

# Timeout for the LLM API call in seconds (5–120).
# CLI flag: --timeout
timeout_seconds: 30

# Save the LLM review (summary + per-issue patch snippets) to a markdown file
# named after the current branch. The file is overwritten on each run so it
# always reflects the latest review for that branch.
# CLI flags: --save-comments=false to disable, --comments-dir to change path
save_comments: true
comments_dir: comments
